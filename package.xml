<?xml version="1.0" encoding="UTF-8"?>
<package format="1" xmlns="https://wiki.freecad.org/Package_Metadata">
  <name>Grid Params Export</name>
  <description>Generate and batch-export multiple variations of a parametric model to 3MF. Define a parameter grid over an App::VarSet (ParameterGrid-style, similar to scikit-learn), preview the resulting variations and their names, then export a chosen set of objects per variation.</description>
  <version>0.1.0</version>
  <date>2026-07-08</date>
  <maintainer email="m.bresson@mailo.eu">Marc Bresson</maintainer>
  <author email="m.bresson@mailo.eu">Marc Bresson</author>
  <license file="LICENSE">MIT</license>
  <url type="repository" branch="main">https://github.com/MarcBresson/FreeCAD-Parametric-Export</url>
  <url type="bugtracker">https://github.com/MarcBresson/FreeCAD-Parametric-Export/issues</url>
  <url type="readme">https://raw.githubusercontent.com/MarcBresson/FreeCAD-Parametric-Export/main/README.md</url>
  <icon>Resources/icons/gridparams.svg</icon>
  <content>
    <workbench>
      <classname>GridParamsWorkbench</classname>
      <name>Grid Params Export</name>
      <icon>Resources/icons/gridparams.svg</icon>
      <subdirectory>.</subdirectory>
    </workbench>
  </content>
  <freecadmin>1.0.0</freecadmin>
  <pythonmin>3.11</pythonmin>
  <tag>parametric</tag>
  <tag>varset</tag>
  <tag>export</tag>
  <tag>batch</tag>
  <tag>3mf</tag>
  <tag>mesh</tag>
</package>
